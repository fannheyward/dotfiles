if (( $+commands[eza] )); then
    alias l='eza'
    alias ls='eza'
    alias tree='eza --tree'
else
    export LS_OPTIONS="-hGF"
    alias l="ls $LS_OPTIONS"
    alias ls="ls $LS_OPTIONS"
fi

